{
  // ─── SMTP ────────────────────────────────────────────────────────────────────
  "EmailUsername": "mittente@dominio.it",
  "EmailPassword": "password-smtp",
  "EmailSmtpServer": "smtps.aruba.it",
  "EmailSmtpServerPort": "465",

  // ─── Database ────────────────────────────────────────────────────────────────
  // Per prove in locale usare la stringa LocalDB qui sotto (e impostare
  // AppSettings:EnsureDbCreated = true in appsettings.Development.json).
  "ConnectionStrings": {
    "DefaultConnection": "Server=tcp:<server>.database.windows.net,1433;Initial Catalog=<database>;Persist Security Info=False;User ID=<user>;Password=<password>;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
  },

  // ─── Azure OpenAI ─────────────────────────────────────────────────────────────
  "AzureOpenAI": {
    "ChatCompletion": {
      "Deployment": "gpt-4o",
      "Endpoint": "https://<risorsa>.openai.azure.com/",
      "ApiKey": "<api-key>",
      "ModelId": "gpt-4o"
    },
    "Embedding": {
      "Deployment": "text-embedding-3-small",
      "Endpoint": "https://<risorsa>.openai.azure.com/",
      "ApiKey": "<api-key>",
      "ModelId": "text-embedding-3-small",
      "Dimensions": 1536
    }
  },

  // ─── Azure AI Services (Text Analytics) ──────────────────────────────────────
  "AzureAiService": {
    "endpointServiceTextAnalisys": "https://<risorsa>.openai.azure.com/",
    "apiKeyServiceTextAnalisys": "<api-key>"
  },

  // ─── CRM API ──────────────────────────────────────────────────────────────────
  "CrmApi": {
    "BaseUrl": "https://<crm-host>/restapi/v1/vtews/query",
    "Username": "<utente-webservice>",
    "Password": "<password-webservice>"
  },

  // ─── API Key demo (usata da ApiKeyAuthFilter / Copilot Studio) ────────────────
  // Va impostata anche nella sezione Demo:ApiKey
  "Demo": {
    "ApiKey": "<chiave-da-comunicare-a-copilot-studio>"
  }
}
